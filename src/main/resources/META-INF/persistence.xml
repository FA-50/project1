<!-- Mybatis의 <Configuration>에 대응 -->

<persistence xmlns="http://java.sun.com/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd"
             version="2.0">

<!--   Mybatis의 <Evironment>에 대응  -->
    <persistence-unit name="hibernate-exp-1">
        <properties>


<!--    JDBC와 달리 DB 드라이버를 직접 정의하지 않아도, 의존성에 정의된 DB의존성(H2, MySQL)의 드라이버를 자동으로 검색하여 드라이버를 연결   -->
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:test-db" />
            <property name="jakarta.persistence.jdbc.user" value="sa" />
            <property name="jakarta.persistence.jdbc.password" value="" />

            <property name="jakarta.persistence.schema-generation.database.action" value="create" />


<!--        콘솔에 SQL문을 출력하도록 하는 태그    -->
            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.format_sql" value="true" />
            <property name="hibernate.highlight_sql" value="true" />
        </properties>

    </persistence-unit>

    <persistence-unit name="hibernate-exp-2">

        <!--    순수 Hibernate는 사용자가 정의한 Entity 클래스를 찾을 수 없으므로, 해당 디렉토리를 설정해야한다.       -->
<!--      클래스 태그 내 Entity 클래스가 저장된 경로를 지정  -->
<!--      이때, 어플리케이션 구동 시 해당 <class>로 등록된 Entity 클래스를 기반으로 Hibernate에 의해 자동으로 DDL-auto 되어 DB Table 생성  -->
        <class>model.s01.Member</class>
        <properties>

            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:test-db" />
            <property name="jakarta.persistence.jdbc.user" value="sa" />
            <property name="jakarta.persistence.jdbc.password" value="" />

            <property name="jakarta.persistence.schema-generation.database.action" value="create" />


            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.format_sql" value="true" />
            <property name="hibernate.highlight_sql" value="true" />



            <property name="hibernate.hbm2ddl.auto" value="create"/>
            <property name="elipselink.logging.level" value="INFO"/>
            <property name="elipselink.logging.level.sql" value="FINE"/>
            <property name="elipselink.logging.parameters" value="true"/>

        </properties>

    </persistence-unit>


    <persistence-unit name="hibernate-exp-3">


        <class>model.s02.Acoount</class>
        <class>model.s02.Accounts</class>
        <class>model.s02.Product</class>
        <class>model.s02.Post</class>
        <class>model.s02.GymMembership</class>
        <properties>

            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:test-db" />
